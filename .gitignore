# ========================================
# FlowSense - Reglas agregadas
# ========================================

# Archivos legacy archivados
._legacy_scratch/

# Videos grandes (no versionar)
video/*.mp4
video/*.avi
video/*.mov

# Modelos YOLO (se descargan automáticamente)
*.pt
!Producto/python/modelos/.gitkeep

# Python
__pycache__/
*.pyc
.venv/
venv/

# Variables de entorno
.env
.env.local
!.env.example

# IDE local
.idea/
.vscode/settings.json

# Archivos de prueba de Python (no deben versionarse)
Producto/python/resultado*.csv
Producto/python/zonas_*.json
Producto/python/tests/__pycache__/
zonas_prueba.json

# Salidas locales
*.log