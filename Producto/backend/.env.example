# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  FlowSense Backend — Variables de entorno                                   │
# │  Copia este archivo como .env y completa con valores reales.                │
# │  NUNCA commitear .env con valores reales.                                   │
# └─────────────────────────────────────────────────────────────────────────────┘

# ── Base de datos (MySQL 8) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=flowsense_db
DB_USER=flowsense
DB_PASSWORD=change_me

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
# Mínimo 32 caracteres aleatorios (256 bits para HS256)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_EXPIRATION_HOURS=24

# ── Email ──────────────────────────────────────────────────────────────────────
# Dev: usar Mailtrap (smtp.mailtrap.io:587)
# Prod: Gmail SMTP con contraseña de aplicación (smtp.gmail.com:587)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_FROM=noreply@flowsense.cl

# ── Python ─────────────────────────────────────────────────────────────────────
# Ruta al ejecutable de Python 3.12 en el sistema
PYTHON_BIN=python3
# Ruta absoluta al script del detector (dentro del contenedor o en el host)
PYTHON_SCRIPT=/app/python/detector.py

# ── Directorios de trabajo ─────────────────────────────────────────────────────
# Deben existir y ser escribibles por el proceso Java
UPLOAD_DIR=/app/uploads
RESULTS_DIR=/app/results
ZONES_DIR=/app/zones

# ── Frontend ───────────────────────────────────────────────────────────────────
# URL base del frontend (usado en links de emails de invitación y recuperación)
FRONTEND_URL=http://localhost:5173
# Orígenes permitidos en CORS (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://tu-app.vercel.app
